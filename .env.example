# Application
APP_NAME=AutoVid
DEBUG=true
VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autovid

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Model API Keys (configure in UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Storage
UPLOAD_DIR=media/uploads
MAX_UPLOAD_SIZE=104857600
